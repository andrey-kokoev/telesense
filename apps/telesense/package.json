{
  "name": "telesense",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names 'WORKER,VITE' --prefix-colors 'blue,green' 'wrangler dev --local' 'vite'",
    "dev:debug": "concurrently --names 'WORKER,VITE' --prefix-colors 'blue,green' 'DEBUG=true wrangler dev --local' 'vite'",
    "build": "vite build",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler/tmp test-results playwright-report",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "health": "curl -s http://localhost:8787/health | jq . || echo 'Health check failed'",
    "logs": "wrangler tail"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250301.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wrangler": "^4.75.0"
  }
}
